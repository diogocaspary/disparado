# =====================================================================
# Uneixo Broadcaster — variáveis de ambiente para o docker-compose.yml
# Copie este arquivo para ".env" na raiz do projeto e ajuste os valores.
# =====================================================================

# ---------------------------------------------------------------------
# Banco de dados (PostgreSQL)
# ---------------------------------------------------------------------
# Usuário do banco de dados Postgres
POSTGRES_USER=uneixo_broadcaster

# Senha do banco de dados Postgres — troque por uma senha forte em produção
POSTGRES_PASSWORD=troque-esta-senha

# Nome do banco de dados usado pela aplicação
POSTGRES_DB=uneixo_broadcaster

# ---------------------------------------------------------------------
# Backend (API)
# ---------------------------------------------------------------------
# Chave secreta usada para assinar os tokens JWT de autenticação.
# Gere um valor longo e aleatório, ex: openssl rand -base64 48
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio

# Credenciais do usuário SUPER_ADMIN criado automaticamente no primeiro
# deploy (o seed é idempotente: se o usuário já existir, nada é alterado).
SEED_ADMIN_EMAIL=admin@uneixochat.com
SEED_ADMIN_PASSWORD=ChangeMe123!

# Porta interna em que o processo Node do backend escuta dentro do container
BACKEND_PORT=3333

# Porta do HOST mapeada para a API do backend (acesso direto/depuração).
# Não é necessária para o funcionamento do frontend, que acessa o backend
# pela rede interna do docker-compose. Pode ser omitida/bloqueada no EasyPanel
# se você não quiser expor a API publicamente.
BACKEND_HOST_PORT=3333

# ---------------------------------------------------------------------
# Frontend (painel admin)
# ---------------------------------------------------------------------
# URL da API usada pelo frontend em BUILD-TIME (compilada dentro do bundle
# estático pelo Vite). Como o nginx do frontend faz proxy de /api para o
# backend, o valor "/api" evita problemas de CORS. Só altere se o frontend
# for consumir a API por um domínio/host diferente.
VITE_API_URL=/api

# Porta do HOST mapeada para o nginx do frontend (onde o EasyPanel/proxy
# reverso deve apontar o domínio público). Padrão: 8080.
FRONTEND_HOST_PORT=8080
